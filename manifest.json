{
  "manifest_version": 3,
  "name": "Smart Link Copier",
  "version": "1.0",
  "description": "Copy smart links with a prompt (GitHub PR, Jira, custom text).",
  "permissions": ["clipboardWrite", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "copy-smart-link": {
      "suggested_key": {
        "default": "Ctrl+Shift+K"
      },
      "description": "Copy Smart Link"
    }
  }
}